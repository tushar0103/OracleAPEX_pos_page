creat ea process when click button 

DECLARE
  l_response CLOB;
BEGIN
  l_response := apex_web_service.make_rest_request(
    p_url         => 'http://localhost:11434/api/generate',
    p_http_method => 'POST',
    p_body        => '{
      "model": "llama3.2",
      "prompt": "' || :P10_PROMPT || '",
      "stream": false
    }'
  );

  :P10_RESPONSE := l_response;
END;

