const SpeechRecognition = window.SpeechRecognition || window.webkitSpeechRecognition; //Check Browser Support
//Different browsers use different names.  chrome use webkitSpeechRecognition 

if (!SpeechRecognition) {
    alert("Speech Recognition is not supported in this browser.");
} else {

    const recognition = new SpeechRecognition();  //Create Recognition Object

    recognition.lang = "en-US";  //This tells the speech engine which language to recognize.  hindi recognition.lang="hi-IN";
    recognition.interimResults = false; //Speech recognition can return two kinds of results.
    recognition.maxAlternatives = 1;

    recognition.onstart = function () {
        console.log("Listening...");
    };

    recognition.onresult = function (event) {

        var text = event.results[0][0].transcript;

        apex.item("P1_PROMPT").setValue(text);  // P1_PROMPT  this is item in which you voice converting into text

        // Click your existing Ask AI button
        apex.event.trigger($("#btn_AI"), "click");   //btn_AI is static id of button on which ajaz call back is whotter by which APi is hitting
